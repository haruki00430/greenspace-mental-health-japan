*~

# OS
.DS_Store
Thumbs.db

# 設定フォルダ（重要！）
.antigravity/
.claude/
.cursor/
.gemini/
.obsidian/

# データファイル（大容量のため除外）
data/raw/
data/interim/*.csv
data/interim/*.parquet
data/interim/*.geojson
data/interim/*.shp
data/interim/*.shx
data/interim/*.dbf
data/interim/*.prj
data/processed/*.csv
data/processed/*.parquet
data/processed/*.geojson

# ただし、最終データセットのメタデータは含める
!data/processed/README.md
!data/interim/README.md

# 一時ファイル
*.tmp
*.bak
*.log

# 大容量図表（最終版のみコミット）
results/figures/*.png
results/figures/*.pdf
results/figures/*.svg
!results/figures/README.md

# Excel一時ファイル
~$*.xlsx
~$*.xls

# R関連（使用する場合）
.RData
.Rhistory
.Rproj.user

# Quarto
.quarto/
*_files/
*.html
*.docx
*.pdf
!04_Manuscripts/*.qmd

# 圧縮ファイル
*.zip
*.tar.gz
*.rar

# セキュリティ（APIキーなど）
.env
secrets.yaml
credentials.json

